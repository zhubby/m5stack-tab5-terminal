BIND_ADDR=127.0.0.1:8080
QUOTE_PROVIDER=mock
WATCHLIST=000001.SH:上证指数,399001.SZ:深证成指,600519.SH:贵州茅台,00700.HK:腾讯控股,09988.HK:阿里巴巴-W
WATCHLIST_FILE=watchlist.json
FRONTEND_DIST_DIR=frontend/dist
STALE_AFTER_SECS=20
MOCK_INTERVAL_MS=3000

# Used by the standalone Vite dev server. Set it in frontend/.env.local or the shell.
# VITE_BACKEND_ORIGIN=http://127.0.0.1:8080

# Required for browser/admin watchlist management.
# Also set this before binding to 0.0.0.0 or exposing the backend on a LAN.
# DEVICE_TOKEN=replace-with-a-random-token

# Required only when QUOTE_PROVIDER=longbridge.
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# LONGBRIDGE_LANGUAGE=zh-CN
